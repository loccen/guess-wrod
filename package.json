{
  "name": "guess-wrod",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "dev:pages": "npm run build && wrangler pages dev dist --port 8788",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "cf:check": "wrangler pages functions build --outdir .wrangler/functions-build",
    "ci:check": "npm run typecheck && npm run test && npm run build && npm run cf:check",
    "deploy:pages": "wrangler pages deploy dist --project-name=guess-wrod"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260517.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.16.0"
  }
}
