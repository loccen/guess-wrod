{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "guess-wrod",
  "compatibility_date": "2026-05-17",
  "pages_build_output_dir": "dist",
  "vars": {
    "AI_MODE": "stub",
    "CAPTCHA_MODE": "bypass",
    "ANALYTICS_MODE": "noop",
    "ARCHIVE_MODE": "file"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "guess-wrod-local",
      "database_id": "local-development-only"
    }
  ],
  "r2_buckets": [],
  "env": {
    "preview": {
      "vars": {
        "AI_MODE": "live",
        "CAPTCHA_MODE": "bypass",
        "ANALYTICS_MODE": "noop",
        "ARCHIVE_MODE": "file",
        "AI_GATEWAY_BYOK_ALIAS": "guess-word",
        "AI_GATEWAY_ENDPOINT_URL": "https://gateway.ai.cloudflare.com/v1/656612e8bac6e750ae630a5ad3320858/guess-wrod-gateway/custom-guessword-deepseek/v1"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "guess-wrod-prod",
          "database_id": "35412c0c-e8b9-4a0b-bf89-ddcdc89b63b3"
        }
      ],
      "r2_buckets": []
    },
    "production": {
      "vars": {
        "AI_MODE": "live",
        "CAPTCHA_MODE": "bypass",
        "ANALYTICS_MODE": "noop",
        "ARCHIVE_MODE": "live",
        "AI_GATEWAY_BYOK_ALIAS": "guess-word",
        "AI_GATEWAY_ENDPOINT_URL": "https://gateway.ai.cloudflare.com/v1/656612e8bac6e750ae630a5ad3320858/guess-wrod-gateway/custom-guessword-deepseek/v1"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "guess-wrod-prod",
          "database_id": "35412c0c-e8b9-4a0b-bf89-ddcdc89b63b3"
        }
      ],
      "r2_buckets": [
        {
          "binding": "R2_LOG_BUCKET",
          "bucket_name": "guess-wrod-archive"
        }
      ]
    }
  }
}
